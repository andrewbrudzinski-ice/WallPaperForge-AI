# ─────────────────────────────────────────────────────────────
# WallpaperForge AI — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# ─────────────────────────────────────────────────────────────

# Supabase (https://app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only key — NEVER expose to the client. Used by API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# AI Image Generation Providers
# Configure at least one. The active provider is chosen by
# IMAGE_PROVIDER below (openai | gemini | stability | mock).
# ─────────────────────────────────────────────────────────────
IMAGE_PROVIDER=mock

# OpenAI (gpt-image-1 / DALL·E 3)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# Google Gemini (Imagen)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

# Stability AI
STABILITY_API_KEY=
STABILITY_IMAGE_MODEL=core

# ─────────────────────────────────────────────────────────────
# App configuration
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Free-tier daily generation limit (premium is unlimited)
FREE_DAILY_GENERATION_LIMIT=10

# ─────────────────────────────────────────────────────────────
# Billing (Stripe) — optional. Without these, premium stays a
# simulated toggle and no checkout/charges occur.
# ─────────────────────────────────────────────────────────────
# Set to "true" to expose the real Upgrade/Manage billing UI.
NEXT_PUBLIC_BILLING_ENABLED=false
# Stripe secret key (server-only).
STRIPE_SECRET_KEY=
# Recurring Price ID for the Premium plan (price_...).
STRIPE_PRICE_ID=
# Signing secret for the /api/billing/webhook endpoint (whsec_...).
STRIPE_WEBHOOK_SECRET=
